[
  {
    "name": "theme_info",
    "theme_name": "Aethelgard Antiques",
    "theme_version": "1.0.0",
    "theme_author": "AI Studio"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#f5f2ed"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Gold)",
        "default": "#c5a059"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary Color",
        "default": "#f9f8f4"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border Color",
        "default": "rgba(0,0,0,0.1)"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "serif"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "sans-serif"
      },
      {
        "type": "range",
        "id": "font_base_size",
        "min": 12,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base Font Size",
        "default": 16
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter/X"
      }
    ]
  },
  {
    "name": "General Settings",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "text",
        "id": "currency_format",
        "label": "Currency Format",
        "default": "${{amount}}"
      }
    ]
  }
]
