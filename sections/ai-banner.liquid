<section class="py-20 bg-black text-white overflow-hidden relative">
  <div class="absolute inset-0 opacity-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-accent/40 via-transparent to-transparent"></div>
  </div>
  
  <div class="container relative z-10 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="text-accent text-[10px] uppercase tracking-[0.5em] font-bold mb-6 block">Personalized Concierge</span>
      <h2 class="text-3xl md:text-5xl font-serif mb-8 leading-tight">Can't find what you're looking for?</h2>
      <p class="text-gray-400 mb-10 text-sm md:text-base leading-relaxed">
        Our AI-powered acquisition engine can source specific pieces from private collections worldwide. 
        Tell us your requirements and let our technology find your next masterpiece.
      </p>
      <button class="bg-accent text-white px-10 h-14 uppercase tracking-widest text-[10px] font-bold hover:bg-white hover:text-black transition-all duration-500">
        Start Private Search
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AI Banner",
  "settings": [],
  "presets": [
    {
      "name": "AI Banner"
    }
  ]
}
{% endschema %}
