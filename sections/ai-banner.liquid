{% if section.settings.show_banner %}
<section 
  class="py-24 overflow-hidden relative"
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
>
  <div class="absolute top-0 right-0 w-1/3 h-full bg-accent/10 blur-[120px] rounded-full translate-x-1/2"></div>
  
  <div class="container relative z-10">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        <span class="text-xs uppercase tracking-[0.4em] font-bold">{{ section.settings.badge_text }}</span>
      </div>
      <h2 class="text-4xl md:text-6xl font-serif mb-8 leading-tight">
        {{ section.settings.heading }}
      </h2>
      <p class="text-lg md:text-xl font-light mb-10 opacity-80 leading-relaxed">
        {{ section.settings.description }}
      </p>
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="group flex items-center gap-4 text-xs uppercase tracking-[0.3em] font-bold">
          {{ section.settings.button_text }}
          <div class="h-[1px] w-12 bg-accent group-hover:w-24 transition-all duration-500"></div>
        </a>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "AI Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "AI Personalized Curation"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading Text",
      "default": "Can't find what you're <br> <span class='italic'>looking for?</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Our AI Curator can help you source specific items from private collections worldwide or recommend pieces based on your existing interior style."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Consult Our AI Curator"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "AI Banner"
    }
  ]
}
{% endschema %}
