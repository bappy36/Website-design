{% if section.settings.show_announcement %}
  <div 
    id="announcement-bar"
    class="relative z-[60] py-2 px-4 flex items-center justify-center transition-all duration-300"
    style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
  >
    <div class="container flex items-center justify-center relative">
      <div class="flex-1 text-center">
        {% for block in section.blocks %}
          <div 
            class="announcement-item {% unless forloop.first %}hidden{% endunless %} animate-fade-in"
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" class="hover:opacity-80 transition-opacity">{% endif %}
            <span class="uppercase tracking-[0.3em] font-bold text-[8px] md:text-[10px]">{{ block.settings.text }}</span>
            {% if block.settings.link != blank %}</a>{% endif %}
          </div>
        {% endfor %}
        
        {% if section.blocks.size == 0 %}
          <span class="uppercase tracking-[0.3em] font-bold text-[10px]">{{ section.settings.text }}</span>
        {% endif %}
      </div>

      {% if section.settings.show_close %}
        <button 
          onclick="document.getElementById('announcement-bar').remove()"
          class="absolute right-0 p-1 hover:opacity-50 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      {% endif %}
    </div>
  </div>

  {% if section.blocks.size > 1 %}
    <script>
      (function() {
        let current = 0;
        const items = document.querySelectorAll('.announcement-item');
        const interval = {{ section.settings.autoplay_speed | default: 5000 }};
        
        setInterval(() => {
          items[current].classList.add('hidden');
          current = (current + 1) % items.length;
          items[current].classList.remove('hidden');
        }, interval);
      })();
    </script>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show Close Button",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Default Text (if no blocks)",
      "default": "Complimentary Worldwide Shipping on Orders Over $5,000"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 10000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Speed",
      "default": 5000
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Complimentary Worldwide Shipping"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Complimentary Worldwide Shipping on Orders Over $5,000" } },
        { "type": "announcement", "settings": { "text": "New Victorian Era Collection Just Arrived" } }
      ]
    }
  ]
}
{% endschema %}
