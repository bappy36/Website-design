{% if section.settings.show_announcement %}
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}" class="block">
  {% endif %}
  <div 
    class="uppercase tracking-[0.3em] text-center font-bold"
    style="
      background-color: {{ section.settings.bg_color }}; 
      color: {{ section.settings.text_color }}; 
      font-size: {{ section.settings.font_size }}px;
      padding-top: {{ section.settings.padding_vertical }}px;
      padding-bottom: {{ section.settings.padding_vertical }}px;
    "
  >
    {{ section.settings.text }}
  </div>
  {% if section.settings.link != blank %}
    </a>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Complimentary Worldwide Shipping on Orders Over $5,000"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Padding (Top/Bottom)",
      "default": 8
    }
  ]
}
{% endschema %}
