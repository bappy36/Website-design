{% if section.settings.show_chatbot %}
<div class="fixed z-[100] flex flex-col items-end gap-4" style="bottom: 24px; {% if section.settings.position == 'right' %}right: 24px;{% else %}left: 24px; align-items: flex-start;{% endif %}">
  {% comment %} Chat Window {% endcomment %}
  <div 
    id="chat-window" 
    class="hidden w-80 md:w-96 bg-white shadow-2xl border border-black/5 flex flex-col overflow-hidden transition-all duration-300 origin-bottom-right"
    style="height: {{ section.settings.window_height }}px;"
  >
    <div class="p-4 border-b flex items-center justify-between bg-black text-white">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span class="text-xs uppercase tracking-widest font-bold">{{ section.settings.bot_name }}</span>
      </div>
      <button id="chat-close" class="hover:opacity-60 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    
    <div class="flex-1 p-4 overflow-y-auto space-y-4 bg-[#f9f8f4]" id="chat-messages">
      <div class="flex gap-3">
        <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-white text-[10px] font-bold">AI</div>
        <div class="flex-1 bg-white p-3 text-sm shadow-sm border border-black/5">
          {{ section.settings.welcome_message }}
        </div>
      </div>
    </div>

    <div class="p-4 border-t bg-white">
      <form id="chat-form" class="flex gap-2">
        <input type="text" placeholder="Type your message..." class="flex-1 bg-[#f5f2ed] border-none outline-none px-4 py-2 text-sm">
        <button type="submit" class="p-2 bg-black text-white hover:bg-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
      </form>
    </div>
  </div>

  {% comment %} Toggle Button {% endcomment %}
  <button 
    id="chat-toggle" 
    class="w-14 h-14 rounded-full shadow-2xl flex items-center justify-center text-white transition-all duration-300 hover:scale-110 active:scale-95"
    style="background-color: {{ section.settings.accent_color }};"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chat-icon"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
  </button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chatToggle = document.getElementById('chat-toggle');
    const chatClose = document.getElementById('chat-close');
    const chatWin = document.getElementById('chat-window');

    if (chatToggle && chatWin) {
      chatToggle.addEventListener('click', () => {
        chatWin.classList.toggle('hidden');
      });
    }

    if (chatClose && chatWin) {
      chatClose.addEventListener('click', () => {
        chatWin.classList.add('hidden');
      });
    }
  });
</script>
{% endif %}

{% schema %}
{
  "name": "Chatbot",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_chatbot",
      "label": "Show Chatbot",
      "default": true
    },
    {
      "type": "text",
      "id": "bot_name",
      "label": "Bot Name",
      "default": "AI Curator"
    },
    {
      "type": "textarea",
      "id": "welcome_message",
      "label": "Welcome Message",
      "default": "Greetings. I am the Aethelgard AI Curator. How may I assist you in your search for timeless treasures today?"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c5a059"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        { "value": "right", "label": "Bottom Right" },
        { "value": "left", "label": "Bottom Left" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "window_height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "label": "Chat Window Height",
      "default": 500
    }
  ],
  "presets": [
    {
      "name": "Chatbot"
    }
  ]
}
{% endschema %}
