<section class="py-20 border-b" style="background-color: {{ section.settings.bg_color }};">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-{{ section.settings.columns_layout }} gap-12">
      {% for block in section.blocks %}
        <div class="flex flex-col items-center text-center" {{ block.shopify_attributes }}>
          <div class="mb-6" style="color: {{ section.settings.icon_color }};">
            {{ block.settings.icon_svg }}
          </div>
          <h3 class="text-xs uppercase tracking-[0.3em] font-bold mb-4">{{ block.settings.title }}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#f9f8f4"
    },
    {
      "type": "select",
      "id": "columns_layout",
      "label": "Columns Layout",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#c5a059"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon (SVG)",
          "info": "Paste SVG code here"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "icon_svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"m9 12 2 2 4-4\"/></svg>",
            "title": "Guaranteed Authenticity",
            "description": "Every piece in our collection is verified by our expert curators and comes with a certificate of provenance."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon_svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"/><path d=\"M15 18H9\"/><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"/><circle cx=\"7\" cy=\"18\" r=\"2\"/><circle cx=\"17\" cy=\"18\" r=\"2\"/></svg>",
            "title": "White Glove Delivery",
            "description": "Complimentary worldwide shipping with specialized handling for delicate and high-value treasures."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon_svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"22 7 13.5 15.5 8.5 10.5 2 17\"/><polyline points=\"16 7 22 7 22 13\"/></svg>",
            "title": "Dynamic Valuation",
            "description": "Our AI-driven pricing model analyzes global auction trends to ensure you receive the most accurate market value."
          }
        }
      ]
    }
  ]
}
{% endschema %}
