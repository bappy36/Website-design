<section class="relative h-[90vh] w-full overflow-hidden flex items-center justify-center">
  {/* Background Image with Overlay */}
  <div 
    class="absolute inset-0 z-0"
    style="background-image: url('https://picsum.photos/seed/antique-shop/1920/1080'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-black/40 backdrop-blur-[2px]"></div>
  </div>

  {/* Content */}
  <div class="container relative z-10 px-4 text-center text-white">
    <div class="animate-fade-in-up">
      <span class="text-xs uppercase tracking-[0.5em] mb-6 block font-medium opacity-80">
        Est. 1892 — London
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-8xl font-serif mb-8 leading-tight">
        Timeless Elegance <br />
        <span class="italic font-serif">For The Modern Home</span>
      </h1>
      <p class="max-w-xl mx-auto text-base md:text-xl font-light mb-10 opacity-90 leading-relaxed">
        Discover our curated collection of rare antiques, meticulously sourced from the finest estates across Europe and Asia.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/collections/all" class="bg-white text-black hover:bg-accent hover:text-white transition-all duration-500 px-10 h-14 flex items-center justify-center uppercase tracking-widest text-[10px] font-bold">
          Explore Collection
        </a>
        <a href="/pages/about" class="border border-white text-white hover:bg-white hover:text-black transition-all duration-500 px-10 h-14 flex items-center justify-center uppercase tracking-widest text-[10px] font-bold">
          Our Story
        </a>
      </div>
    </div>
  </div>

  {/* Scroll Indicator */}
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-[1px] h-16 bg-white/30 relative">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-white"></div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
