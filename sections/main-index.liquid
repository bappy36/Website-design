<section class="py-24 bg-[#f5f2ed]">
  <div class="container">
    <div class="flex flex-col md:flex-row items-center justify-between mb-16 gap-8">
      <div>
        <span class="text-xs uppercase tracking-[0.4em] text-accent font-bold mb-4 block">The Collection</span>
        <h2 class="text-4xl md:text-5xl font-serif">Curated Masterpieces</h2>
      </div>
      
      <div class="flex flex-wrap gap-2 border-b border-black/5">
        <a href="#" class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-accent bg-transparent transition-all">All</a>
        <a href="#" class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-transparent hover:border-accent bg-transparent transition-all">Vintage Decor</a>
        <a href="#" class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-transparent hover:border-accent bg-transparent transition-all">Antique Ceramics</a>
        <a href="#" class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-transparent hover:border-accent bg-transparent transition-all">Collectible Figurines</a>
        <a href="#" class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-transparent hover:border-accent bg-transparent transition-all">Rare Books</a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
      {% if collections.all.products.size > 0 %}
        {% for product in collections.all.products limit: 3 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        <!-- Mock Products if store is empty -->
        {% render 'product-card' %}
        {% render 'product-card' %}
        {% render 'product-card' %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
