<section class="py-24 bg-[#fdfcf8]">
  <div class="container">
    <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-8">
      <div class="max-w-xl">
        <span class="text-accent text-[10px] uppercase tracking-[0.4em] font-bold mb-4 block">Curated Selection</span>
        <h2 class="text-5xl md:text-6xl font-serif leading-tight">Rare Finds & <br><span class="italic">Timeless Pieces</span></h2>
      </div>
      <p class="text-muted-foreground max-w-xs text-sm leading-relaxed italic">
        "Each item in our collection is hand-vetted for its historical significance and artistic merit."
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
      {% comment %} 
        In a real Shopify store, you would loop through products:
        {% for product in collections.all.products limit: 3 %}
      {% endcomment %}
      
      <!-- Mock Product 1 -->
      <div class="group cursor-pointer">
        <div class="relative aspect-[4/5] overflow-hidden bg-muted mb-6">
          <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="Product">
          <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-md px-3 py-1 text-[10px] uppercase tracking-widest font-bold">New Arrival</div>
        </div>
        <h3 class="text-xl font-serif mb-2">Victorian Silver Tea Set</h3>
        <p class="text-accent text-sm tracking-widest">$2,450</p>
      </div>

      <!-- Mock Product 2 -->
      <div class="group cursor-pointer">
        <div class="relative aspect-[4/5] overflow-hidden bg-muted mb-6">
          <img src="https://images.unsplash.com/photo-1618220179428-22790b461013?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="Product">
        </div>
        <h3 class="text-xl font-serif mb-2">Art Deco Lounge Chair</h3>
        <p class="text-accent text-sm tracking-widest">$1,800</p>
      </div>

      <!-- Mock Product 3 -->
      <div class="group cursor-pointer">
        <div class="relative aspect-[4/5] overflow-hidden bg-muted mb-6">
          <img src="https://images.unsplash.com/photo-1533090161767-e6ffed986c88?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="Product">
        </div>
        <h3 class="text-xl font-serif mb-2">18th Century Wall Clock</h3>
        <p class="text-accent text-sm tracking-widest">$3,200</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
