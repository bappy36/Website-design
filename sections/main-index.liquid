<section class="py-24 bg-[#fdfcf8]">
  <div class="container">
    <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-8">
      <div class="max-w-xl">
        <span class="text-accent text-[10px] uppercase tracking-[0.4em] font-bold mb-4 block">Curated Selection</span>
        <h2 class="text-5xl md:text-6xl font-serif leading-tight">Rare Finds & <br><span class="italic">Timeless Pieces</span></h2>
      </div>
      <p class="text-muted-foreground max-w-xs text-sm leading-relaxed italic">
        "Each item in our collection is hand-vetted for its historical significance and artistic merit."
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
      {% if collections.all.products.size > 0 %}
        {% for product in collections.all.products limit: 3 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        <!-- Mock Products if store is empty -->
        {% render 'product-card' %}
        {% render 'product-card' %}
        {% render 'product-card' %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
