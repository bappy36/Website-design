<section class="py-24 bg-[#f5f2ed]">
  <div class="container">
    <h1 class="text-4xl md:text-6xl font-serif mb-16">Our Curations</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {% for collection in collections %}
        <a href="{{ collection.url }}" class="group block overflow-hidden bg-white">
          <div class="aspect-[16/9] overflow-hidden">
            {% if collection.image %}
              <img src="{{ collection.image | img_url: '800x' }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full bg-gray-100' }}
            {% endif %}
          </div>
          <div class="p-8 text-center">
            <h2 class="text-2xl font-serif mb-2">{{ collection.title }}</h2>
            <p class="text-[10px] uppercase tracking-widest opacity-40">{{ collection.all_products_count }} Artifacts</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List Collections",
  "settings": []
}
{% endschema %}
