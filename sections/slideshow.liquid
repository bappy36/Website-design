<section class="slideshow-wrapper relative h-[90vh] overflow-hidden" id="Slideshow-{{ section.id }}">
  <div class="slides flex transition-transform duration-700 h-full">
    {% for block in section.blocks %}
      <div class="slide min-w-full h-full relative flex items-center justify-center text-center text-white" {{ block.shopify_attributes }}>
        <div class="absolute inset-0 z-0 bg-cover bg-center" style="background-image: url('{{ block.settings.image | img_url: '1920x' | default: 'https://picsum.photos/seed/' | append: block.id | append: '/1920/1080' }}');">
          <div class="absolute inset-0 bg-black/40"></div>
        </div>
        <div class="container relative z-10 px-4">
          <span class="text-xs uppercase tracking-[0.5em] mb-6 block font-medium opacity-80">{{ block.settings.subheading }}</span>
          <h2 class="text-4xl md:text-8xl font-serif mb-8 leading-tight">{{ block.settings.heading }}</h2>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mt-8">
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="bg-white text-black hover:bg-accent hover:text-white transition-all duration-500 px-10 h-14 flex items-center justify-center uppercase tracking-widest text-[10px] font-bold">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {% comment %} Controls {% endcomment %}
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-4 z-20">
    {% for block in section.blocks %}
      <button class="w-3 h-3 rounded-full border border-white/50 transition-all slideshow-dot" onclick="goToSlide({{ forloop.index0 }})"></button>
    {% endfor %}
  </div>
</section>

<script>
  let currentSlide = 0;
  const slideCount = {{ section.blocks.size }};
  
  function goToSlide(index) {
    currentSlide = index;
    const slides = document.querySelector('#Slideshow-{{ section.id }} .slides');
    slides.style.transform = `translateX(-${index * 100}%)`;
    
    // Update dots
    document.querySelectorAll('#Slideshow-{{ section.id }} .slideshow-dot').forEach((dot, i) => {
      dot.style.background = i === index ? 'white' : 'transparent';
      dot.style.borderColor = i === index ? 'white' : 'white/50';
    });
  }

  // Auto slide
  {% if section.settings.auto_rotate %}
    setInterval(() => {
      currentSlide = (currentSlide + 1) % slideCount;
      goToSlide(currentSlide);
    }, {{ section.settings.change_slides_speed }} * 1000);
  {% endif %}

  // Initialize
  document.addEventListener('DOMContentLoaded', () => goToSlide(0));
</script>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "The Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Timeless Elegance"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
