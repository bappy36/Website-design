{% assign product_title = product.title | default: "Rare Antique Piece" %}
{% assign product_price = product.price | money | default: "$1,200.00" %}
{% assign product_url = product.url | default: "#" %}
{% assign aspect_ratio = aspect_ratio | default: "3/4" %}
{% assign show_sold_out = show_sold_out | default: true %}
{% assign show_price = show_price | default: true %}
{% assign hover_zoom = hover_zoom | default: true %}

<div class="group cursor-pointer transition-all duration-500 hover:-translate-y-2">
  <div class="relative overflow-hidden bg-[#f5f2ed] border-none shadow-none" style="aspect-ratio: {{ aspect_ratio }};">
    <a href="{{ product_url }}" class="block w-full h-full">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '800x' }}" class="w-full h-full object-cover transition-transform duration-1000 {% if hover_zoom %}group-hover:scale-110{% endif %}" alt="{{ product_title }}" referrerPolicy="no-referrer">
      {% else %}
        {% if product == empty %}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200' }}
        {% else %}
          <img src="https://picsum.photos/seed/{{ product_title | handleize }}/800/1000" class="w-full h-full object-cover transition-transform duration-1000 {% if hover_zoom %}group-hover:scale-110{% endif %}" alt="{{ product_title }}" referrerPolicy="no-referrer">
        {% endif %}
      {% endif %}
    </a>
    
    {% comment %} Quick Add Button {% endcomment %}
    <div class="absolute bottom-4 right-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
      <button class="w-10 h-10 rounded-full bg-white text-black hover:bg-accent hover:text-white shadow-xl flex items-center justify-center transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </button>
    </div>

    {% comment %} Category Badge {% endcomment %}
    <div class="absolute top-4 left-4">
      <span class="text-[10px] uppercase tracking-widest bg-white/80 backdrop-blur-sm px-3 py-1 font-medium">
        {% if product.type != blank %}{{ product.type }}{% else %}Vintage Decor{% endif %}
      </span>
    </div>

    {% if show_sold_out and product.available == false and product != empty %}
      <div class="absolute top-4 right-4 bg-black text-white px-3 py-1 text-[10px] uppercase tracking-widest font-bold">Sold Out</div>
    {% endif %}
  </div>
  
  <div class="mt-6 text-center">
    <a href="{{ product_url }}">
      <h3 class="text-lg font-serif mb-1 group-hover:text-accent transition-colors">{{ product_title }}</h3>
      {% if show_price %}
        <p class="text-sm font-medium tracking-widest text-muted-foreground">{{ product_price }}</p>
      {% endif %}
    </a>
  </div>
</div>
