{% assign product_title = product.title | default: "Rare Antique Piece" %}
{% assign product_price = product.price | money | default: "$1,200.00" %}
{% assign product_url = product.url | default: "#" %}
{% assign aspect_ratio = aspect_ratio | default: "3/4" %}
{% assign show_sold_out = show_sold_out | default: true %}
{% assign show_price = show_price | default: true %}
{% assign hover_zoom = hover_zoom | default: true %}
{% assign category_name = mock_category | default: product.type | default: "Vintage Decor" %}

<div class="group cursor-pointer">
  <div class="relative overflow-hidden bg-[#f5f2ed] border-none shadow-none" style="aspect-ratio: {{ aspect_ratio }};">
    <a href="{{ product_url }}" class="block w-full h-full">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '800x' }}" class="w-full h-full object-cover transition-transform duration-1000 {% if hover_zoom %}group-hover:scale-110{% endif %}" alt="{{ product_title }}" referrerPolicy="no-referrer">
      {% else %}
        {% if product == empty %}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200 transition-transform duration-1000 group-hover:scale-105' }}
        {% else %}
          <img src="https://picsum.photos/seed/{{ product_title | handleize }}/800/1000" class="w-full h-full object-cover transition-transform duration-1000 {% if hover_zoom %}group-hover:scale-110{% endif %}" alt="{{ product_title }}" referrerPolicy="no-referrer">
        {% endif %}
      {% endif %}
    </a>
    
    {% comment %} Quick View Overlay {% endcomment %}
    <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
      <button class="bg-white/90 backdrop-blur-md text-black px-8 py-3 text-[10px] font-bold uppercase tracking-widest translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 hover:bg-black hover:text-white">
        Quick View
      </button>
    </div>

    {% comment %} Category Badge {% endcomment %}
    <div class="absolute top-4 left-4 z-10">
      <span class="text-[9px] uppercase tracking-[0.2em] bg-white px-2.5 py-1.5 font-bold shadow-sm border border-black/5">
        {{ category_name }}
      </span>
    </div>

    {% if show_sold_out and product.available == false and product != empty %}
      <div class="absolute top-4 right-4 bg-black text-white px-3 py-1 text-[10px] uppercase tracking-widest font-bold z-10">Sold Out</div>
    {% endif %}
  </div>
  
  <div class="mt-8">
    <a href="{{ product_url }}" class="block text-center px-4">
      <h3 class="text-xl font-serif mb-2 group-hover:text-accent transition-colors leading-tight">{{ product_title }}</h3>
      {% if show_price %}
        <p class="text-[10px] font-bold tracking-[0.3em] text-accent uppercase">{{ product_price }}</p>
      {% endif %}
    </a>
  </div>
</div>
