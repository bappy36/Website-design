{% doc %}
  @prompt
    I need a header with 10000% cutomisation opions 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px {{ block.settings.border_style }} {{ block.settings.border_color }};
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    position: {{ block.settings.position }};
    top: 0;
    left: 0;
    right: 0;
    z-index: {{ block.settings.z_index }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
  }

  .ai-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
    gap: {{ block.settings.content_gap }}px;
    flex-direction: {{ block.settings.layout_direction }};
  }

  .ai-header-logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
  }

  .ai-header-logo-{{ ai_gen_id }} img {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    border-radius: {{ block.settings.logo_border_radius }}px;
    opacity: {{ block.settings.logo_opacity }};
  }

  .ai-header-logo-{{ ai_gen_id }} img:hover {
    opacity: {{ block.settings.logo_hover_opacity }};
    transform: scale({{ block.settings.logo_hover_scale }});
    transition: all {{ block.settings.transition_speed }}s ease;
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: 60px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.logo_border_radius }}px;
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-header-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    line-height: {{ block.settings.line_height }};
    text-transform: {{ block.settings.text_transform }};
    text-decoration: {{ block.settings.text_decoration }};
  }

  .ai-header-nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.nav_gap }}px;
    flex-direction: {{ block.settings.nav_direction }};
    align-items: center;
  }

  .ai-header-nav-link-{{ ai_gen_id }} {
    font-family: {{ block.settings.nav_font.family }}, {{ block.settings.nav_font.fallback_families }};
    font-weight: {{ block.settings.nav_font.weight }};
    font-size: {{ block.settings.nav_font_size }}px;
    color: {{ block.settings.nav_color }};
    text-decoration: none;
    padding: {{ block.settings.nav_link_padding }}px;
    border-radius: {{ block.settings.nav_link_border_radius }}px;
    background-color: {{ block.settings.nav_link_bg_color }};
    border: {{ block.settings.nav_link_border_width }}px solid {{ block.settings.nav_link_border_color }};
    transition: all {{ block.settings.transition_speed }}s ease;
    text-transform: {{ block.settings.nav_text_transform }};
    letter-spacing: {{ block.settings.nav_letter_spacing }}px;
  }

  .ai-header-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.nav_hover_color }};
    background-color: {{ block.settings.nav_hover_bg_color }};
    border-color: {{ block.settings.nav_hover_border_color }};
    transform: translateY({{ block.settings.nav_hover_translate }}px);
  }

  .ai-header-button-{{ ai_gen_id }} {
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_font_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all {{ block.settings.transition_speed }}s ease;
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    box-shadow: {{ block.settings.button_shadow_x }}px {{ block.settings.button_shadow_y }}px {{ block.settings.button_shadow_blur }}px {{ block.settings.button_shadow_color }};
  }

  .ai-header-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text_color }};
    background-color: {{ block.settings.button_hover_bg_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: scale({{ block.settings.button_hover_scale }});
    box-shadow: {{ block.settings.button_hover_shadow_x }}px {{ block.settings.button_hover_shadow_y }}px {{ block.settings.button_hover_shadow_blur }}px {{ block.settings.button_hover_shadow_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-header-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_right }}px {{ block.settings.mobile_padding_bottom }}px {{ block.settings.mobile_padding_left }}px;
    }

    .ai-header-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout_direction }};
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-header-logo-{{ ai_gen_id }} img,
    .ai-header-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_logo_width }}px;
    }

    .ai-header-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-header-nav-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_nav_direction }};
      gap: {{ block.settings.mobile_nav_gap }}px;
    }

    .ai-header-nav-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_nav_font_size }}px;
    }

    .ai-header-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_button_font_size }}px;
    }
  }
{% endstyle %}

<header-{{ ai_gen_id }} class="ai-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-header-container-{{ ai_gen_id }}">
    {% if block.settings.show_logo %}
      <div class="ai-header-logo-{{ ai_gen_id }}">
        <a href="/">
          {% if block.settings.logo %}
            <img
              src="{{ block.settings.logo | image_url: width: 600 }}"
              alt="{{ shop.name }}"
              width="{{ block.settings.logo_width }}"
              height="auto"
              loading="lazy"
            >
          {% else %}
            <div class="ai-header-logo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </a>
      </div>
    {% endif %}

    {% if block.settings.show_text and block.settings.header_text != blank %}
      <div class="ai-header-text-{{ ai_gen_id }}">
        {{ block.settings.header_text }}
      </div>
    {% endif %}

    {% if block.settings.show_navigation %}
      <nav class="ai-header-nav-{{ ai_gen_id }}">
        {% if block.settings.nav_link_1_text != blank %}
          <a href="{{ block.settings.nav_link_1_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_1_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_2_text != blank %}
          <a href="{{ block.settings.nav_link_2_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_2_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_3_text != blank %}
          <a href="{{ block.settings.nav_link_3_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_3_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_4_text != blank %}
          <a href="{{ block.settings.nav_link_4_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_4_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_5_text != blank %}
          <a href="{{ block.settings.nav_link_5_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_5_text }}
          </a>
        {% endif %}
      </nav>
    {% endif %}

    {% if block.settings.show_button and block.settings.button_text != blank %}
      <a href="{{ block.settings.button_url }}" class="ai-header-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</header-{{ ai_gen_id }}>

<script>
  (function() {
    class Header{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupStickyBehavior();
      }

      setupStickyBehavior() {
        if (this.style.position === 'sticky' || this.style.position === 'fixed') {
          let lastScroll = 0;
          window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            if (currentScroll > lastScroll) {
              this.style.transform = 'translateY(-100%)';
            } else {
              this.style.transform = 'translateY(0)';
            }
            lastScroll = currentScroll;
          });
        }
      }
    }

    customElements.define('header-{{ ai_gen_id }}', Header{{ ai_gen_id }});
  })();
</script>

